# =====================================================================
# Radar Combustivel - Pipeline MongoDB -> Redis
# Copie este arquivo para .env e ajuste se necessario.
# =====================================================================

# ---------- MongoDB ----------
# Para Change Streams o Mongo precisa estar em modo replica set.
# O docker-compose deste projeto sobe o Mongo ja com --replSet rs0.
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGO_DB=radar_combustivel

# Colecoes (nao alterar a menos que mude no Mongo)
MONGO_COL_POSTOS=postos
MONGO_COL_LOCALIZACOES=localizacoes_postos
MONGO_COL_PRECOS=eventos_preco
MONGO_COL_BUSCAS=buscas_usuarios
MONGO_COL_AVALIACOES=avaliacoes_interacoes

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- Pipeline ----------
# Tamanho do batch usado no backfill inicial (100k docs)
BACKFILL_BATCH_SIZE=2000

# Worker pool para processamento paralelo do backfill
BACKFILL_WORKERS=4

# Tempo de retencao das TimeSeries (em ms). 30 dias por padrao.
TS_RETENTION_MS=2592000000

# Janela usada nos rankings de "alta/queda" (em horas)
RANKING_WINDOW_HOURS=24

# ---------- Streamlit ----------
STREAMLIT_REFRESH_SECONDS=10

# ---------- Observabilidade ----------
LOG_LEVEL=INFO
METRICS_INTERVAL_SECONDS=15
